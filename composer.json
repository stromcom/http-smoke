{
    "name": "stromcom/http-smoke",
    "description": "Professional HTTP smoke testing toolkit with a fluent DSL, parallel execution, capture chains, sessions and pluggable variable sources / reporters / HTTP clients.",
    "type": "library",
    "license": "MIT",
    "keywords": ["http", "smoke", "testing", "smoke-test", "ci", "monitoring", "curl"],
    "authors": [
        {
            "name": "Stromek",
            "email": "petr.biza@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Enables the GuzzleClient HTTP backend (planned for v1.1)."
    },
    "autoload": {
        "psr-4": {
            "Stromcom\\HttpSmoke\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Stromcom\\HttpSmoke\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/http-smoke"
    ],
    "scripts": {
        "test": "phpunit",
        "phpunit": "phpunit",
        "phpstan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "ci": [
            "@cs",
            "@phpstan",
            "@test"
        ],
        "dev-server": "@php examples/dev-server/reset-state.php && @php -S 127.0.0.1:8080 examples/dev-server/server.php",
        "dev-server:reset": "@php examples/dev-server/reset-state.php",
        "examples": [
            "@php examples/dev-server/reset-state.php",
            "@php bin/http-smoke dev --config-dir=examples/SmokeHttp --smoke-json=examples/smokeHttp.json --no-github-summary"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable"
}
